{
    "$schema": "https://apify.com/schemas/v1/input.ide.json",
    "title": "Python Playwright Scraper",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "start_urls": {
            "title": "Start URLs",
            "type": "array",
            "description": "URLs to start with",
            "prefill": [
                {
                    "url": "https://apify.com"
                }
            ],
            "editor": "requestListSources",
            "default": [
                { "url": "https://books.toscrape.com/" }
            ]
        },
        "max_pages_to_scrape":{
            "title":"Max Pages to Scrap",
            "type": "integer",
            "description":"defines Maximum pages to scrape",
            "minimum":1,
            "maximum":50,
            "default":40
        },
        "total_books_to_scrape":{
            "title": "Total No. Books To scrape",
            "type":"integer",
            "description": "Defines Total no. of Books to want",
            "default":50,
            "minimum":1,
            "maximum":1000
        }
    },
    "required": ["start_urls"]
}
